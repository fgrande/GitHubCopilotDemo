<div class="fixed inset-0 bg-pixel-black flex items-center justify-center p-4 z-50">
    <div class="pixel-modal p-8 max-w-sm w-full text-center animate-glitch">
        <div class="text-4xl mb-4">🎉</div>
        <h2 class="text-2xl font-bold text-neon-yellow mb-4">BINGO!</h2>
        <p class="text-pixel-black mb-6 text-xs">YOU COMPLETED A LINE!</p>

        <button    @onclick="OnDismiss"        class="w-full pixel-button py-4 px-6 text-xs">
            KEEP PLAYING
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}