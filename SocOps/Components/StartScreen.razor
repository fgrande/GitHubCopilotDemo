<div class="flex flex-col items-center justify-center min-h-full p-6 bg-pixel-black">
    <div class="text-center max-w-md">
        <h1 class="text-5xl font-bold text-neon-blue mb-4 animate-flicker">SOC OPS</h1>
        <p class="text-lg text-neon-pink mb-8">SOCIAL BINGO</p>

        <div class="bg-pixel-white border-pixel p-6 mb-8 pixel-modal">
            <h2 class="font-bold text-pixel-black mb-4 text-sm">HOW TO PLAY</h2>
            <ul class="text-left text-pixel-black text-xs space-y-3">
                <li>• FIND PEOPLE WHO MATCH THE QUESTIONS</li>
                <li>• TAP A SQUARE WHEN YOU FIND A MATCH</li>
                <li>• GET 5 IN A ROW TO WIN!</li>
            </ul>
        </div>

        <button    @onclick="OnStart"        class="w-full pixel-button py-6 px-8 text-sm">
            START GAME
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}