@using SocOps.Models

<div class="flex flex-col min-h-full bg-gray-50">
    <!-- Header -->
    <header class="flex items-center justify-between p-4 bg-pixel-black text-pixel-white border-pixel">
        <button     @onclick="OnReset"          class="pixel-button text-xs px-4 py-2">
            ← BACK
        </button>
        <h1 class="font-bold text-neon-blue text-lg">SOC OPS</h1>
        <div class="w-20"></div>
    </header>

    <!-- Instructions -->
    <p class="text-center text-gray-500 text-sm py-2 px-4">
        Tap a square when you find someone who matches it.
    </p>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="bg-neon-yellow text-pixel-black text-center py-4 font-bold text-sm animate-glitch border-pixel">
            🎉 BINGO! YOU GOT A LINE! 🎉
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-3">
        <BingoBoard      Board="@Board"    WinningSquareIds="@WinningSquareIds"            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}