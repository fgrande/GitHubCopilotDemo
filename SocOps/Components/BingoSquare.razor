@using SocOps.Models

<button    @onclick="OnClick"    disabled="@Square.IsFreeSpace"    class="@GetCssClasses()"    aria-pressed="@Square.IsMarked"
           aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-0.5 right-0.5 text-green-600 text-xs">✓</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "relative flex items-center justify-center p-3 text-center pixel-square select-none min-h-[80px] text-xs leading-tight font-bold";

        var stateClasses = Square.IsMarked
            ? IsWinning
                ? "bg-neon-yellow text-pixel-black animate-glitch"
                : "bg-neon-green text-pixel-black"
            : "bg-pixel-white text-pixel-black hover:bg-pixel-gray hover:animate-flicker";

        var freeSpaceClasses = Square.IsFreeSpace ? "text-sm" : "";

        return $"{baseClasses} {stateClasses} {freeSpaceClasses}";
    }
}